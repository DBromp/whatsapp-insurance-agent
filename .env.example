# Used only for local development against Databricks Connect.
# In production, secrets live in Databricks Secrets — never commit real values here.

DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<personal-access-token>
DATABRICKS_CATALOG=nmstx_whatsapp_pipeline

# For local testing only — production reads from Databricks Secrets scope `nmstx-secrets`
GEMINI_API_KEY=
PII_SALT=
